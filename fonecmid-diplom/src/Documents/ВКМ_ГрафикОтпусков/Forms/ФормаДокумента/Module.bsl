
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	ПересчитатьВсеПризнакиНасервере();

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыОтпускаСотрудников

&НаКлиенте
Процедура ОтпускаСотрудниковПриОкончанииРедактирования(Элемент, НоваяСтрока, ОтменаРедактирования)

	ПересчитатьВсеПризнакиНасервере();
	Элементы.ОтпускаСотрудников.Обновить();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура График(Команда)
	
	АдресВременногоХранилища = ГрафикНаСервере();
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("АдресВременногоХранилища", АдресВременногоХранилища);
	
	ОткрытьФорму("Документ.ВКМ_ГрафикОтпусков.Форма.АнализГрафика", ПараметрыФормы, ЭтотОбъект);
	
КонецПроцедуры

#КонецОбласти
	
#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ПересчитатьВсеПризнакиНасервере()
	
	ДокументОбъект = РеквизитФормыВЗначение("Объект");

	Если ДокументОбъект.ОтпускаСотрудников.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ДниПоСотрудникам = Новый Соответствие;
	
	Для Каждого Строка Из ДокументОбъект.ОтпускаСотрудников Цикл
		
		КоличествоДней = (Строка.ДатаОкончания - Строка.ДатаНачала) / 86400 + 1;
		
		ТекущиеДни = ДниПоСотрудникам.Получить(Строка.Сотрудник);
		
		Если ТекущиеДни = Неопределено Тогда
			ДниПоСотрудникам.Вставить(Строка.Сотрудник, КоличествоДней);
		Иначе
			ДниПоСотрудникам.Вставить(Строка.Сотрудник, ТекущиеДни + КоличествоДней);
		КонецЕсли;
		
	КонецЦикла;
	
	Для Каждого Строка Из ДокументОбъект.ОтпускаСотрудников Цикл
		
		ВсегоДней = ДниПоСотрудникам.Получить(Строка.Сотрудник);
		
		Если ВсегоДней = Неопределено Тогда
			ВсегоДней = 0;
		КонецЕсли;
		
		Строка.Более28Дней = (ВсегоДней > 28);
		
	КонецЦикла;
	
	ЗначениеВРеквизитФормы(ДокументОбъект,"Объект");
	
КонецПроцедуры


&НаСервере
Функция ГрафикНаСервере()
	
	ДокументОбъект = РеквизитФормыВЗначение("Объект");
	
	ДанныеСотрудников = ДокументОбъект.ОтпускаСотрудников; 
	ПередаваемыеДанные = Новый Массив;
	
	Для Каждого Данные Из ДанныеСотрудников Цикл
		
		ДанныеДляПередачи = Новый Структура;
		ДанныеДляПередачи.Вставить("Сотрудник", Данные.Сотрудник.Наименование);
		ДанныеДляПередачи.Вставить("ДатаНачала", Данные.ДатаНачала);
		ДанныеДляПередачи.Вставить("ДатаОкончания", Данные.ДатаОкончания);
		ДанныеДляПередачи.Вставить("ВидРасчета", "Отпуск");  
		
		ПередаваемыеДанные.Добавить(ДанныеДляПередачи);
		
	КонецЦикла;
	
	АдресВременногоХранилища = ПоместитьВоВременноеХранилище(ПередаваемыеДанные, Новый УникальныйИдентификатор);
	
	Возврат АдресВременногоХранилища;
	
КонецФункции


#КонецОбласти









