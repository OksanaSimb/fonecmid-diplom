
#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий

Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	
	Сотрудники = Новый Массив;
	
	Для Каждого Строка Из ОсновныеНачисления Цикл
		Сотрудники.Добавить(Строка.Сотрудник);
	КонецЦикла;
	
	СформироватьДвижения();
	
	РассчитатьОклад();
	
	РассчитатьПроцентВыполненныхРабот();
	
	РассчитатьОтпуск(Сотрудники);
	
	РассчитатьНДФЛ();
	
	РассчитатьНачисленияСотрудникам();
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура СформироватьДвижения()

	Движения.ВКМ_ФактическиеОтпуска.Записывать = Истина; 
	
	Движения.ВКМ_ОсновныеНачисления.Очистить();
	Движения.ВКМ_ОсновныеНачисления.Записать();
	
	Для Каждого Строка Из ОсновныеНачисления Цикл
		
		Если ТипЗнч(Строка.ВидРасчета) = Тип("ПланВидовРасчетаСсылка.ВКМ_ОсновныеНачисления") Тогда
			
			Движение = Движения.ВКМ_ОсновныеНачисления.Добавить();
			Движение.ПериодРегистрации = Дата;
			Движение.ПериодДействияНачало = Строка.ДатаНачала;
			Движение.ПериодДействияКонец = Строка.ДатаОкончания;
			Движение.ВидРасчета = Строка.ВидРасчета;
			Движение.Сотрудник = Строка.Сотрудник;
			Движение.Подразделение = Строка.Подразделение;
			Движение.ГрафикРаботы = Строка.ГрафикРаботы;
			Движение.БазовыйПериодНачало = Строка.ДатаНачала;
			Движение.БазовыйПериодКонец = Строка.ДатаОкончания; 
			
			Движение = Движения.ВКМ_Удержания.Добавить(); 
			Движение.ПериодРегистрации = Дата;
			Движение.ВидРасчета = ПланыВидовРасчета.ВКМ_Удержания.НДФЛ;
			Движение.Сотрудник = Строка.Сотрудник;
			Движение.Подразделение = Строка.Подразделение; 
			Движение.БазовыйПериодНачало = Строка.ДатаНачала;
			Движение.БазовыйПериодКонец = Строка.ДатаОкончания;
			Движение.ПериодДействияНачало = Строка.ДатаНачала;
			Движение.ПериодДействияКонец = Строка.ДатаОкончания;
			
		КонецЕсли;
		
		Если Строка.ВидРасчета = ПланыВидовРасчета.ВКМ_ОсновныеНачисления.Отпуск Тогда
			
			Движение = Движения.ВКМ_ФактическиеОтпуска.Добавить();
			Движение.Период = Дата;
			Движение.Сотрудник = Строка.Сотрудник;
			
			КоличествоДней = (Строка.ДатаОкончания - Строка.ДатаНачала) / 86400 + 1;
			Движение.ДниФакт = КоличествоДней;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Движения.ВКМ_ОсновныеНачисления.Записать();
	Движения.ВКМ_ФактическиеОтпуска.Записать();
	Движения.ВКМ_Удержания.Записать();
	
КонецПроцедуры

Процедура РассчитатьОклад()     
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ВКМ_ОсновныеНачисленияДанныеГрафика.НомерСтроки КАК НомерСтроки,
		|	ЕСТЬNULL(ВКМ_УсловияОплатыСотрудниковСрезПоследних.Оклад, 0) КАК Оклад,
		|	ВКМ_ОсновныеНачисленияДанныеГрафика.РабочихДнейПериодДействия КАК План,
		|	ВКМ_ОсновныеНачисленияДанныеГрафика.РабочихДнейФактическийПериодДействия КАК Факт
		|ИЗ
		|	РегистрРасчета.ВКМ_ОсновныеНачисления.ДанныеГрафика(Регистратор = &Ссылка
		|	И ВидРасчета = ЗНАЧЕНИЕ(ПланВидовРасчета.ВКМ_ОсновныеНачисления.Оклад)) КАК ВКМ_ОсновныеНачисленияДанныеГрафика
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ВКМ_УсловияОплатыСотрудников.СрезПоследних(&Период, Сотрудник В
		|			(ВЫБРАТЬ
		|				ВКМ_ОсновныеНачисления.Сотрудник КАК Сотрудник
		|			ИЗ
		|				РегистрРасчета.ВКМ_ОсновныеНачисления КАК ВКМ_ОсновныеНачисления
		|			ГДЕ
		|				ВКМ_ОсновныеНачисления.Регистратор = &Ссылка
		|				И ВКМ_ОсновныеНачисления.ВидРасчета = ЗНАЧЕНИЕ(ПланВидовРасчета.ВКМ_ОсновныеНачисления.Оклад))) КАК
		|			ВКМ_УсловияОплатыСотрудниковСрезПоследних
		|		ПО ВКМ_ОсновныеНачисленияДанныеГрафика.Сотрудник = ВКМ_УсловияОплатыСотрудниковСрезПоследних.Сотрудник";
	
	Запрос.УстановитьПараметр("Период", КонецДня(Дата));
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		Движение = Движения.ВКМ_ОсновныеНачисления[Выборка.НомерСтроки - 1];
		
		Если Выборка.План = 0 Тогда
			Движение.Результат = 0;
		Иначе
			Движение.Результат = Выборка.Оклад * Выборка.Факт / Выборка.План; 
		КонецЕсли;
		
	КонецЦикла;
	
	Движения.ВКМ_ОсновныеНачисления.Записать(, Истина);
	
КонецПроцедуры

Процедура РассчитатьПроцентВыполненныхРабот()
		
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ВКМ_ОсновныеНачисления.Сотрудник КАК Сотрудник,
		|	СУММА(ЕСТЬNULL(ВКМ_ВыполненныеСотрудникомРаботы.СуммаКОплате, 0)) КАК СуммаКОплате
		|ИЗ
		|	РегистрРасчета.ВКМ_ОсновныеНачисления КАК ВКМ_ОсновныеНачисления
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ВКМ_ВыполненныеСотрудникомРаботы КАК ВКМ_ВыполненныеСотрудникомРаботы
		|		ПО ВКМ_ОсновныеНачисления.Сотрудник = ВКМ_ВыполненныеСотрудникомРаботы.Сотрудник
		|		И ВКМ_ВыполненныеСотрудникомРаботы.Период
		|			МЕЖДУ ВКМ_ОсновныеНачисления.ПериодДействияНачало И ВКМ_ОсновныеНачисления.ПериодДействияКонец
		|ГДЕ
		|	ВКМ_ОсновныеНачисления.Регистратор = &Ссылка
		|	И ВКМ_ОсновныеНачисления.ВидРасчета = &ВидРасчета
		|СГРУППИРОВАТЬ ПО
		|	ВКМ_ОсновныеНачисления.Сотрудник";
					
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Запрос.УстановитьПараметр("ВидРасчета", ПланыВидовРасчета.ВКМ_ОсновныеНачисления.ПроцентОтРабот);
	
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	
	ПроцентыОтРабот = Новый Соответствие;
	
	Пока Выборка.Следующий() Цикл
		ПроцентыОтРабот.Вставить(Выборка.Сотрудник, Выборка.СуммаКОплате);
	КонецЦикла;
			
	Для Каждого Движение Из Движения.ВКМ_ОсновныеНачисления Цикл
		
		Если Движение.ВидРасчета = ПланыВидовРасчета.ВКМ_ОсновныеНачисления.ПроцентОтРабот Тогда
			
			ПроцентОтРабот = ПроцентыОтРабот.Получить(Движение.Сотрудник);
			
			Если ПроцентОтРабот = Неопределено Тогда
				Движение.Результат = 0;
			Иначе
				Движение.Результат = ПроцентОтРабот;
			КонецЕсли;
		КонецЕсли;
			
	КонецЦикла;
	
	Движения.ВКМ_ОсновныеНачисления.Записать(, Истина);
	
КонецПроцедуры

Процедура РассчитатьОтпуск(Сотрудники)
	
	ДатаНачалаРасчета = ДобавитьМесяц(НачалоМесяца(Дата), -12);
	ДатаОкончанияРасчета = КонецМесяца(ДобавитьМесяц(Дата, -1));
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ВКМ_ОсновныеНачисления.Сотрудник КАК Сотрудник,
		|	СУММА(ЕСТЬNULL(ВКМ_ОсновныеНачисления.Результат, 0)) КАК СуммаНачислений
		|ИЗ
		|	РегистрРасчета.ВКМ_ОсновныеНачисления КАК ВКМ_ОсновныеНачисления
		|ГДЕ
		|	ВКМ_ОсновныеНачисления.Сотрудник В (&СписокСотрудников)
		|	И ВКМ_ОсновныеНачисления.ПериодДействияНачало >= &ДатаНачалаРасчета
		|	И ВКМ_ОсновныеНачисления.ПериодДействияКонец <= &ДатаОкончанияРасчета
		|	И ВКМ_ОсновныеНачисления.ВидРасчета <> &ВидОтпуска
		|СГРУППИРОВАТЬ ПО
		|	ВКМ_ОсновныеНачисления.Сотрудник";
	
	Запрос.УстановитьПараметр("ДатаНачалаРасчета", ДатаНачалаРасчета);
	Запрос.УстановитьПараметр("ДатаОкончанияРасчета", ДатаОкончанияРасчета);
	Запрос.УстановитьПараметр("СписокСотрудников", Сотрудники);
	Запрос.УстановитьПараметр("ВидОтпуска", ПланыВидовРасчета.ВКМ_ОсновныеНачисления.Отпуск);
	
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	
	СуммыНачислений = Новый Соответствие;
	
	Пока Выборка.Следующий() Цикл
		СуммыНачислений.Вставить(Выборка.Сотрудник, Выборка.СуммаНачислений);
	КонецЦикла;
	
	ЗапросГрафик = Новый Запрос;
	ЗапросГрафик.Текст =
		"ВЫБРАТЬ
		|	Сотрудники.Ссылка КАК Сотрудник,
		|	Сотрудники.ГрафикРаботы КАК ГрафикРаботы,
		|	СУММА(ЕСТЬNULL(ВКМ_ГрафикиРаботы.РабочихДней, 0)) КАК РабочихДней
		|ИЗ
		|	Справочник.ВКМ_Сотрудники КАК Сотрудники
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ВКМ_ГрафикиРаботы КАК ВКМ_ГрафикиРаботы
		|		ПО Сотрудники.ГрафикРаботы = ВКМ_ГрафикиРаботы.ГрафикРаботы
		|			И ВКМ_ГрафикиРаботы.Дата МЕЖДУ &ДатаНачалаРасчета И &ДатаОкончанияРасчета
		|ГДЕ
		|	Сотрудники.Ссылка В (&СписокСотрудников)
		|СГРУППИРОВАТЬ ПО
		|	Сотрудники.Ссылка,
		|	Сотрудники.ГрафикРаботы";
	
	ЗапросГрафик.УстановитьПараметр("СписокСотрудников", Сотрудники);
	ЗапросГрафик.УстановитьПараметр("ДатаНачалаРасчета", ДатаНачалаРасчета);
	ЗапросГрафик.УстановитьПараметр("ДатаОкончанияРасчета", ДатаОкончанияРасчета);
	
	РезультатГрафика = ЗапросГрафик.Выполнить();
	ВыборкаГрафика = РезультатГрафика.Выбрать();
	
	РабочиеДни = Новый Соответствие;
	
	Пока ВыборкаГрафика.Следующий() Цикл
		РабочиеДни.Вставить(ВыборкаГрафика.Сотрудник, ВыборкаГрафика.РабочихДней);
	КонецЦикла;
	
	Для Каждого Движение Из Движения.ВКМ_ОсновныеНачисления Цикл
		
		Если Движение.ВидРасчета = ПланыВидовРасчета.ВКМ_ОсновныеНачисления.Отпуск Тогда
			
			СуммаНачислений = СуммыНачислений.Получить(Движение.Сотрудник);
			РабочихДнейСотрудника = РабочиеДни.Получить(Движение.Сотрудник);
			
			Если СуммаНачислений = Неопределено ИЛИ РабочихДнейСотрудника = Неопределено Тогда
				Движение.Результат = 0;
				Продолжить;
			КонецЕсли;
			
			Если СуммаНачислений = 0 Или РабочихДнейСотрудника = 0 Тогда
				Движение.Результат = 0;
				Продолжить;
			КонецЕсли;
			
			СреднедневнойЗаработок = СуммаНачислений / РабочихДнейСотрудника;
			КоличествоДнейОтпуска = Окр(((Движение.ПериодДействияКонец - Движение.ПериодДействияНачало) / 86400) + 1, 2);
			Движение.Результат = Окр(СреднедневнойЗаработок * КоличествоДнейОтпуска, 2);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Движения.ВКМ_ОсновныеНачисления.Записать(, Истина);
	
КонецПроцедуры

Процедура РассчитатьНДФЛ()   
	
	Измерения = Новый Массив;
	Измерения.Добавить("Сотрудник");
	
	Разрезы = Новый Массив;
	Разрезы.Добавить("ВидРасчета");
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВКМ_УдержанияБазаВКМ_ОсновныеНачисления.Сотрудник КАК Сотрудник,
		|	ВКМ_УдержанияБазаВКМ_ОсновныеНачисления.РезультатБаза КАК РезультатБаза,
		|	ВКМ_УдержанияБазаВКМ_ОсновныеНачисления.ВидРасчетаРазрез КАК ВидРасчетаРазрез
		|ИЗ
		|	РегистрРасчета.ВКМ_Удержания.БазаВКМ_ОсновныеНачисления(&Измерения, &Измерения, &Разрезы, Регистратор = &Ссылка) КАК ВКМ_УдержанияБазаВКМ_ОсновныеНачисления";
	
	Запрос.УстановитьПараметр("Измерения", Измерения);
	Запрос.УстановитьПараметр("Разрезы", Разрезы);
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();  
  
	СтрокиПоСотруднику = Новый Соответствие;

	Пока Выборка.Следующий() Цикл
		Сотрудник = Выборка.Сотрудник;
		
		СтруктураСтроки = Новый Структура;
		СтруктураСтроки.Вставить("ВидРасчета", Выборка.ВидРасчетаРазрез);
		СтруктураСтроки.Вставить("Сумма", Выборка.РезультатБаза);
		
		МассивСтрок = СтрокиПоСотруднику.Получить(Сотрудник);
		Если МассивСтрок = Неопределено Тогда
			МассивСтрок = Новый Массив;
			СтрокиПоСотруднику.Вставить(Сотрудник, МассивСтрок);
		КонецЕсли;
		МассивСтрок.Добавить(СтруктураСтроки);
	КонецЦикла;
	
	Для Каждого Движение Из Движения.ВКМ_Удержания Цикл
		
		Сотрудник = Движение.Сотрудник;
		МассивСтрок = СтрокиПоСотруднику.Получить(Сотрудник);
		
		Если МассивСтрок = Неопределено ИЛИ МассивСтрок.Количество() = 0 Тогда
			Движение.База = 0;
			Движение.Результат = 0;
			Продолжить;
		КонецЕсли;
		
		СтруктураСтроки = МассивСтрок[0];
		МассивСтрок.Удалить(0);
		
		База = СтруктураСтроки.Сумма;
		Движение.База = База;
		Движение.Результат = -Окр(База * 0.13, 2);
		
	КонецЦикла;
		
	Движения.ВКМ_Удержания.Записать(, Истина);  

КонецПроцедуры

Процедура РассчитатьНачисленияСотрудникам()
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	Начисления.Сотрудник КАК Сотрудник,
		|	Начисления.СуммаНачислений КАК СуммаНачислений,
		|	ЕСТЬNULL(Удержания.СуммаУдержаний, 0) КАК СуммаУдержаний
		|ИЗ
		|	(ВЫБРАТЬ
		|		ВКМ_ОсновныеНачисления.Сотрудник КАК Сотрудник,
		|		СУММА(ЕСТЬNULL(ВКМ_ОсновныеНачисления.Результат, 0)) КАК СуммаНачислений
		|	ИЗ
		|		РегистрРасчета.ВКМ_ОсновныеНачисления КАК ВКМ_ОсновныеНачисления
		|	ГДЕ
		|		ВКМ_ОсновныеНачисления.Регистратор = &Ссылка
		|	СГРУППИРОВАТЬ ПО
		|		ВКМ_ОсновныеНачисления.Сотрудник
		|) КАК Начисления
		|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
		|			ВКМ_Удержания.Сотрудник КАК Сотрудник,
		|			СУММА(ЕСТЬNULL(ВКМ_Удержания.Результат, 0)) КАК СуммаУдержаний
		|		ИЗ
		|			РегистрРасчета.ВКМ_Удержания КАК ВКМ_Удержания
		|		ГДЕ
		|			ВКМ_Удержания.Регистратор = &Ссылка
		|		СГРУППИРОВАТЬ ПО
		|			ВКМ_Удержания.Сотрудник
		|	) КАК Удержания
		|		ПО Начисления.Сотрудник = Удержания.Сотрудник";
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	
	// регистр ВзаиморасчетыССотрудниками
	Движения.ВКМ_ВзаиморасчетыССотрудниками.Записывать = Истина;
	
	Пока Выборка.Следующий() Цикл
		
		Сотрудник = Выборка.Сотрудник;
		СуммаНачислений = Выборка.СуммаНачислений;
		СуммаУдержаний = Выборка.СуммаУдержаний;
		
		ИтоговаяСумма = СуммаНачислений + СуммаУдержаний;
		
		Если ИтоговаяСумма = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		Движение = Движения.ВКМ_ВзаиморасчетыССотрудниками.Добавить();
		Движение.Период = Дата;
		Движение.Сотрудник = Сотрудник;
		Движение.Сумма = ИтоговаяСумма;
		
	КонецЦикла;
	
	Движения.ВКМ_ВзаиморасчетыССотрудниками.Записать();
	
КонецПроцедуры

